using System.Net;
using System.Text.Json;
using Microsoft.Extensions.Caching.Distributed;
using Microsoft.Extensions.Options;
using StackExchange.Redis;
using IDatabase = StackExchange.Redis.IDatabase;

namespace Inlaks.MultitenantStarter.Auth.Infrastructure
{
    /// <summary>
    /// Repository class for managing Redis cache operations including storing, retrieving, and deleting cached data.
    /// </summary>
    public class RedisCacheRepository
    {
        private readonly IDistributedCache _cache;
        private readonly RedisCacheSettings _redisCacheSettings;
        private readonly string _connectionString;
        
        /// <summary>
        /// Initializes a new instance of the <see cref="RedisCacheRepository"/> class.
        /// </summary>
        /// <param name="cache">The distributed cache implementation for Redis operations.</param>
        /// <param name="cacheSettings">The configuration settings for Redis cache connection and expiration.</param>
        public RedisCacheRepository(IDistributedCache cache, IOptions<RedisCacheSettings> cacheSettings)
        {
            _cache = cache;
            _redisCacheSettings = cacheSettings.Value;
            _connectionString = $"{_redisCacheSettings.Host}:{_redisCacheSettings.Port},password={_redisCacheSettings.Password}";

        }
        
        /// <summary>
        /// Deletes all cache keys that match the specified search pattern.
        /// </summary>
        /// <param name="search">The search pattern to match against cache keys. Wildcards are added automatically.</param>
        /// <returns>A task that represents the asynchronous operation. The task result contains true if the operation succeeds.</returns>
        public async Task<bool> DeleteKeys(string search)
        {
            var lstKeys = await FetchKeys(search);

            foreach (var key in lstKeys)
            {
                await _cache.RemoveAsync(key);
            }

            return true;
        }

        /// <summary>
        /// Fetches all cache keys that match the specified search pattern.
        /// </summary>
        /// <param name="search">The search pattern to match against cache keys. Wildcards are added automatically.</param>
        /// <returns>A task that represents the asynchronous operation. The task result contains a list of matching cache key names.</returns>
        public async Task<List<string>> FetchKeys(string search)
        {
            ConfigurationOptions options = ConfigurationOptions.Parse(_connectionString);
            ConnectionMultiplexer connection = ConnectionMultiplexer.Connect(options);
            IDatabase db = connection.GetDatabase();
            EndPoint endPoint = connection.GetEndPoints().First();
            var pattern = $"*{search}*";
            RedisKey[] keys = connection.GetServer(endPoint).Keys(pattern: pattern).ToArray();

            return keys.Select(p => p.ToString()).ToList();
        }

        /// <summary>
        /// Retrieves the cached value for the specified key.
        /// </summary>
        /// <param name="key">The cache key to retrieve the value for.</param>
        /// <returns>A task that represents the asynchronous operation. The task result contains the cached string value, or null if the key does not exist.</returns>
        public async Task<string?> Get(string key)
        {
            var value = await _cache.GetStringAsync(key);

            if (value != null)
            {
                return value;
            }

            return null;
        }

        /// <summary>
        /// Retrieves all cache keys from the Redis database.
        /// </summary>
        /// <returns>A task that represents the asynchronous operation. The task result contains a list of all cache key names.</returns>
        public async Task<List<string>> GetAllListElementsFromAllKeys()
        {
            ConfigurationOptions options = ConfigurationOptions.Parse(_connectionString);
            ConnectionMultiplexer connection = ConnectionMultiplexer.Connect(options);
            IDatabase db = connection.GetDatabase();
            EndPoint endPoint = connection.GetEndPoints().First();
            var pattern = $"*";
            RedisKey[] keys = connection.GetServer(endPoint).Keys(pattern: pattern).ToArray();

            return keys.Select(p => p.ToString()).ToList();
        }

        /// <summary>
        /// Refreshes the sliding expiration timeout for the specified cache key.
        /// </summary>
        /// <param name="search">The cache key to refresh.</param>
        /// <returns>A task that represents the asynchronous operation. The task result contains true if the refresh succeeds, false otherwise.</returns>
        public async Task<bool> Refresh(string search)
        {
            bool isSucceed = false;
            try
            {

                _cache.Refresh(search);
                isSucceed = true;
                return isSucceed;
            }
            catch (Exception ex)
            {
                return isSucceed;
            }
        }

        /// <summary>
        /// Sets a key-value pair in the Redis cache with configured expiration settings.
        /// </summary>
        /// <param name="payload">The cache key-value payload containing the key and value to store.</param>
        /// <returns>A task that represents the asynchronous operation. The task result contains true if the operation succeeds.</returns>
        public async Task<bool> Set(RadisCacheModel.CacheKeyVal payload)
        {
            var timeOut = new DistributedCacheEntryOptions
            {
                AbsoluteExpirationRelativeToNow = TimeSpan.FromMinutes(_redisCacheSettings.AbsoluteExpirationRelativeToNowInHours),
                SlidingExpiration = TimeSpan.FromMinutes(_redisCacheSettings.SlidingExpirationInMins)
            };

            _cache.SetString(payload.key, JsonSerializer.Serialize(payload.value), timeOut);

            return true;
        }
    }
}
