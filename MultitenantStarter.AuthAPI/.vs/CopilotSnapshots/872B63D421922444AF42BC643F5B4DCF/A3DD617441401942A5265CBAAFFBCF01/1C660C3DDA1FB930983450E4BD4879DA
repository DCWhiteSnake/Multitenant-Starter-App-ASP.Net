using System.Text;
using Inlaks.MultitenantStarter.Auth.Infrastructure;
using Inlaks.MultitenantStarter.Investments.Infrastructure;
using Microsoft.AspNetCore.Authentication.JwtBearer;
using Microsoft.EntityFrameworkCore;
using Microsoft.IdentityModel.Tokens;

var builder = WebApplication.CreateBuilder(args);

builder.Services.AddControllers();
builder.Services.AddOpenApi();

var jwtSection = builder.Configuration.GetSection("Jwt");
var issuer = jwtSection.GetValue<string>("Issuer");
var audience = jwtSection.GetValue<string>("Audience");
var secret = jwtSection.GetValue<string>("Secret");
var key = new SymmetricSecurityKey(Encoding.UTF8.GetBytes(secret));

builder.Services.AddAuthentication(JwtBearerDefaults.AuthenticationScheme)
    .AddJwtBearer(options =>
    {
        options.TokenValidationParameters = new TokenValidationParameters
        {
            ValidateIssuer = true,
            ValidateAudience = true,
            ValidateIssuerSigningKey = true,
            ValidateLifetime = true,
            ValidIssuer = issuer,
            ValidAudience = audience,
            IssuerSigningKey = key
        };
    });

builder.Services.AddAuthorization(options =>
{
    options.AddPolicy("RequireTenant", policy => policy.RequireClaim("tenantId").RequireClaim("apiKey"));
});

builder.Services.AddHttpContextAccessor();
var masterConnectionString = builder.Configuration.GetConnectionString("MasterConnection");
builder.Services.AddDbContext<TenantDbContext>(options =>
    options.UseSqlServer(masterConnectionString));

builder.Services.AddScoped<TenantDbContext>();
builder.Services.AddScoped<TenantRegistryService>();
builder.Services.AddScoped<Inlaks.MultitenantStarter.Investments.Infrastructure.AppDbContextFactory>();

var app = builder.Build();

// Ensure master TenantDbContext is created
using (var scope = app.Services.CreateScope())
{
    var tenantDbContext = scope.ServiceProvider.GetRequiredService<TenantDbContext>();
    tenantDbContext.Database.EnsureCreated();
}

// Fetch all tenants and apply migrations to their databases
using (var scope = app.Services.CreateScope())
{
    var tenantRegistryService = scope.ServiceProvider.GetRequiredService<TenantRegistryService>();
    
    try
    {
        var tenants = await tenantRegistryService.GetAllTenants();
        
        foreach (var tenant in tenants)
        {
            try
            {
                // Create InvestmentsAppDbContext for each tenant
                var optionsBuilder = new DbContextOptionsBuilder<InvestmentsAppDbContext>();
                optionsBuilder.UseSqlServer(tenant.ConnectionString);
                
                using var investmentsDbContext = new InvestmentsAppDbContext(optionsBuilder.Options);
                
                // Apply pending migrations
                await investmentsDbContext.Database.MigrateAsync();
                
                Console.WriteLine($"Successfully applied migrations for tenant: {tenant.Name} (ID: {tenant.Id})");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error applying migrations for tenant {tenant.Name} (ID: {tenant.Id}): {ex.Message}");
            }
        }
    }
    catch (Exception ex)
    {
        Console.WriteLine($"Error fetching tenants: {ex.Message}");
    }
}

// Configure the HTTP request pipeline.
if (app.Environment.IsDevelopment())
{
    app.MapOpenApi();
}

app.UseHttpsRedirection();

app.UseAuthentication();
app.UseAuthorization();

app.MapControllers();

app.Run();