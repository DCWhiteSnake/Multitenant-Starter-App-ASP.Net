using Microsoft.EntityFrameworkCore;

namespace Inlaks.MultitenantStarter.TenantService
{
    internal class TenantDbContextFactory(string _connectionString)
    {
        public TenantDbContext CreateDbContext()
        {
            var optionsBuilder = new DbContextOptionsBuilder<TenantDbContext>();
            optionsBuilder.UseSqlServer(_connectionString); 

            return (TenantDbContext)Activator.CreateInstance(typeof(TenantDbContext), optionsBuilder.Options)!;
        }
    }
}