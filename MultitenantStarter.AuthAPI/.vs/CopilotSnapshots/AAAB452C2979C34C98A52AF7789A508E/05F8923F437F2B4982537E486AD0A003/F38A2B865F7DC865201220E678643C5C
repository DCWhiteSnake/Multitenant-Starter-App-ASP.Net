using Inlaks.MultitenantStarter.Auth.Infrastructure.Entities;
using Inlaks.MultitenantStarter.TenantService;
using Microsoft.AspNetCore.Authentication;
using Microsoft.AspNetCore.Identity;
using Microsoft.AspNetCore.Mvc;

namespace Inlaks.MultitenantStarter.AuthAPI.Controllers
{
    [ApiController]
    [Route("api/[controller]")]
    public class AuthController(ILogger<AuthController> _logger, AuthService _authService, TenantRegistryService _tenantRegistryService) : ControllerBase
    {
        private readonly ILogger<AuthController> _logger = _logger;

        [HttpPost("log-in")]
        public IActionResult SignIn(string username, string password)
        {
            var userModel = _authService.SignIn(username, password);
            return Ok(new { Message = "SignIn endpoint hit", Username = username, Password = password });
        }

        [HttpPost("Register")]
        public IActionResult SignIn(string username, string adminEmail, string organizationName)
        {
            var userModel = _tenantRegistryService.AddTenant(_tenantRegistryService)
            return Ok(new { Message = "SignIn endpoint hit", Username = username, Password = password });
        }
    }
}