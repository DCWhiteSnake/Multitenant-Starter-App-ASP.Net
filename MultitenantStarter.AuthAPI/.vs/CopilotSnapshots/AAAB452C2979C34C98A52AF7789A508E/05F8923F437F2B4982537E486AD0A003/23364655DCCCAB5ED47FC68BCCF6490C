using Inlaks.MultitenantStarter.Auth.Infrastructure.Entities;
using Inlaks.MultitenantStarter.TenantService;
using Microsoft.AspNetCore.Authentication;
using Microsoft.AspNetCore.Identity;
using Microsoft.AspNetCore.Mvc;

namespace Inlaks.MultitenantStarter.AuthAPI.Controllers
{
    [ApiController]
    [Route("api/[controller]")]
    public class AuthController(ILogger<AuthController> _logger, AuthService _authService, TenantRegistryService _tenantRegistryService) : ControllerBase
    {
        private readonly ILogger<AuthController> _logger = _logger;

        [HttpPost("log-in")]
        public async Task<IActionResult> SignIn(string username, string password)
        {
            var userModel = await _authService.SignIn(username, password);
            if (userModel is null)
            {
                return Unauthorized();
            }
            return Ok(userModel);
        }

        [HttpPost("register-tenant")]
        public IActionResult RegisterTenant(string organizationName)
        {
            // stub: real implementation not requested in this task
            return Ok(new { message = $"Registered tenant: {organizationName}" });
        }
    }
}