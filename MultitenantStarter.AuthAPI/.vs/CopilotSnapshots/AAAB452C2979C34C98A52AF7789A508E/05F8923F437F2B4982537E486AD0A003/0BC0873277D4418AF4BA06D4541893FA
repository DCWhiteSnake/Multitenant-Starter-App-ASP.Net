using Inlaks.MultitenantStarter.TenantService;

namespace Inlaks.MultitenantStarter.Auth.Infrastructure
{
    public class AuthService(AppDbContextFactory _appDbContextFactory, TenantRegistryService _tenantRegistryService)
    {
        private readonly AppDbContextFactory _appDbContextFactory = _appDbContextFactory;
        public async Task<UserModel> SignIn(string username, string password)
        {
            using var dbContext = _appDbContextFactory.CreateDbContext();
            var user = dbContext.Users.FirstOrDefault(u => u.UserName == username);
            if (user == null)
            {
                return null;
            }
            var tenant = await _tenantRegistryService.Get(user.TenantId);
            return new UserModel
            {
                Id = user.Id,
                Username = user.UserName,
                Email = user.Email,
                Token = "dummy-token",
                TenantName = tenant.Name
            };
        }
    }
}
